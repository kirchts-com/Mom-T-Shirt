<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TshirtFormMockup.AboutPage"
             Title="About: Mom™ Pro"
             BackgroundColor="{StaticResource Gray950}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20"
                             HorizontalOptions="Fill"
                             VerticalOptions="Start"
                             MaximumWidthRequest="560">

            <!-- ═══ TOP — Title ═══ -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Fill">
                <Label Text="Mom™ Pro"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Start"
                       TextColor="{StaticResource White}" />

                <BoxView HeightRequest="1"
                         Color="{StaticResource Gray600}"
                         Margin="0,4" />

                <Label Text="Does everything, complains about nothing"
                       FontSize="16"
                       FontAttributes="Italic"
                       HorizontalTextAlignment="Start"
                       TextColor="{StaticResource Gray300}" />

                <Label Text="Background processes running at all times"
                       FontSize="14"
                       HorizontalTextAlignment="Start"
                       TextColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <!-- ═══ MIDDLE — Core About-Box Content ═══ -->
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray600}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Gray900}"
                    Padding="24,20">

                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="16" RowSpacing="10">

                    <!-- Version -->
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Version:"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray300}" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Text="1.0"
                           TextColor="{StaticResource White}" />

                    <!-- Build -->
                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Build:"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray300}" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="Indestructible"
                           TextColor="{StaticResource White}" />

                    <!-- Uptime -->
                    <Label Grid.Row="2" Grid.Column="0"
                           Text="Uptime:"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray300}" />
                    <Label Grid.Row="2" Grid.Column="1"
                           Text="24/7"
                           TextColor="{StaticResource White}" />

                    <!-- License -->
                    <Label Grid.Row="3" Grid.Column="0"
                           Text="License:"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray300}" />
                    <Label Grid.Row="3" Grid.Column="1"
                           Text="Lifetime"
                           TextColor="{StaticResource White}" />

                    <!-- Permissions -->
                    <Label Grid.Row="4" Grid.Column="0"
                           Text="Permissions:"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray300}" />
                    <Label Grid.Row="4" Grid.Column="1"
                           Text="Full Access"
                           TextColor="{StaticResource White}" />

                    <!-- Support Email -->
                    <Label Grid.Row="5" Grid.Column="0"
                           Text="Support Email:"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray300}" />
                    <Label Grid.Row="5" Grid.Column="1"
                           Text="nosupportneeded@mompro.local"
                           TextColor="{StaticResource White}" />
                </Grid>
            </Border>

            <!-- ═══ FOOTER — Small Text ═══ -->
            <VerticalStackLayout Spacing="4" HorizontalOptions="Fill" Margin="0,10,0,0">
                <Label Text="© Forever"
                       FontSize="11"
                       HorizontalTextAlignment="Start"
                       TextColor="{StaticResource Gray500}" />
                <Label Text="All Rights Reserved"
                       FontSize="11"
                       HorizontalTextAlignment="Start"
                       TextColor="{StaticResource Gray500}" />
                <Label Text="Unauthorized Arguments Will Be Ignored"
                       FontSize="11"
                       FontAttributes="Italic"
                       HorizontalTextAlignment="Start"
                       TextColor="{StaticResource Gray500}" />
            </VerticalStackLayout>

            <!-- Close Button -->
           <Button Text="OK"
                  Clicked="OnCloseClicked"
                  BackgroundColor="#F0F0F0"
                  BorderColor="#B0B0B0"
                  BorderWidth="1"
                  TextColor="#333333"
                  CornerRadius="8"
                  WidthRequest="120"
                  HorizontalOptions="Start"
                  Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
