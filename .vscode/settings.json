{
    "chat.tools.terminal.autoApprove": {
        "dotnet build": true,
        "dotnet new": true,
        "dotnet restore": true,
        "Start-Process": true,
        "New-Item": true,
        "Out-Null": true,
        "Copy-Item": true,
        "Move-Item": true,
        "/^dotnet --list-sdks$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "git add": true,
        "git commit": true,
        "git push": true,
        "git init": true
    }
}