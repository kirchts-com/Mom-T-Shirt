<Window xmlns="https://github.com/avaloniaui"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="0"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="1024"
    x:Class="TshirtFormMockup.MainWindow"
    Title="{Binding TitleBarText}">

    <DockPanel>
                <!-- Custom Title Bar -->
                    <DockPanel DockPanel.Dock="Top" Height="100" Background="#222" PointerPressed="OnTitleBarPointerPressed">
                        <TextBlock Text="{Binding TitleBarText}" FontSize="60" Foreground="White" VerticalAlignment="Center" Margin="30,0,0,0" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0">
                            <Button Content="_" Width="60" Height="60" FontSize="40" Click="OnMinimizeClick" />
                            <Button Content="□" Width="60" Height="60" FontSize="40" Click="OnMaximizeClick" />
                            <Button Content="X" Width="60" Height="60" FontSize="40" Click="OnCloseClick" Background="#c00" Foreground="White" />
                        </StackPanel>
                    </DockPanel>
        <!-- ═══ Menu Bar ═══ -->
        <Menu DockPanel.Dock="Top" FontSize="42" Height="70">
            <MenuItem Header="{Binding MenuFile}" FontSize="42">
                <MenuItem Header="{Binding MenuNew}" Tag="File/New" Click="OnMenuClick" />
                <MenuItem Header="{Binding MenuOpen}" Tag="File/Open" Click="OnMenuClick" />
                <MenuItem Header="{Binding MenuSave}" Tag="File/Save" Click="OnMenuClick" />
                <Separator />
                <MenuItem Header="{Binding MenuExit}" Tag="File/Exit" Click="OnMenuClick" />
            </MenuItem>
            <MenuItem Header="{Binding MenuEdit}" FontSize="42">
                <MenuItem Header="{Binding MenuUndo}" Tag="Edit/Undo" Click="OnMenuClick" />
                <MenuItem Header="{Binding MenuRedo}" Tag="Edit/Redo" Click="OnMenuClick" />
                <Separator />
                <MenuItem Header="{Binding MenuCopy}" Tag="Edit/Copy" Click="OnMenuClick" />
                <MenuItem Header="{Binding MenuPaste}" Tag="Edit/Paste" Click="OnMenuClick" />
            </MenuItem>
            <MenuItem Header="{Binding MenuView}" FontSize="42">
                <MenuItem Header="{Binding MenuRefresh}" Tag="View/Refresh" Click="OnMenuClick" />
                <MenuItem Header="{Binding MenuToggleTheme}" Tag="View/Toggle Theme" Click="OnMenuClick" />
            </MenuItem>
            <MenuItem Header="{Binding MenuHelp}" FontSize="42">
                <MenuItem Header="{Binding MenuAbout}" Tag="Help/About" Click="OnMenuClick" />
            </MenuItem>
        </Menu>

        <!-- ═══ Main Content + About Overlay ═══ -->
        <Panel>

            <!-- Terminal-style content -->
            <ScrollViewer Background="Black" Padding="16">
                <SelectableTextBlock Name="TerminalOutput"
                                     FontFamily="Consolas"
                                     FontSize="42"
                                     Foreground="#C0C0C0"
                                     Text="{Binding TerminalOutputText}" />
            </ScrollViewer>

            <!-- ═══ About Dialog Overlay ═══ -->
            <Panel Name="AboutOverlay" IsVisible="False" Background="#80000000">

                <Border CornerRadius="12"
                        BorderBrush="#404040"
                        BorderThickness="1"
                        Background="#141414"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="1120"
                        Height="1058"
                        Padding="0">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="30" Spacing="16">


                            <!-- TOP — Title -->
                            <TextBlock Text="{Binding AboutTitle}"
                                       FontSize="80"
                                       FontWeight="Bold"
                                       Foreground="White" />

                            <Separator Height="1" Background="#404040" />

                            <!-- Emphasized subtitle -->
                            <TextBlock Text="{Binding AboutSubtitle}"
                                       FontSize="38"
                                       FontWeight="SemiBold"
                                       Foreground="#ACACAC"
                                       Margin="0,10,0,0" />
                            <TextBlock Text="{Binding AboutBackgroundProcesses}"
                                       FontSize="34"
                                       Foreground="#919191"
                                       Margin="0,8,0,28" />

                            <!-- MIDDLE — Details -->
                            <Border CornerRadius="8"
                                    BorderBrush="#404040"
                                    BorderThickness="1"
                                    Background="#212121"
                                    Padding="20,16">

                                <StackPanel>
                                    <Grid ColumnDefinitions="Auto,*"
                                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                                        <Grid.Styles>
                                            <Style Selector="TextBlock">
                                                <Setter Property="Margin" Value="0,4" />
                                            </Style>
                                        </Grid.Styles>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding AboutVersionLabel}" FontWeight="Bold" Foreground="#B0B0B0" FontSize="36" Margin="0,4,14,4" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AboutVersion}" Foreground="White" FontSize="40" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding AboutBuildLabel}" FontWeight="Bold" Foreground="#B0B0B0" FontSize="36" Margin="0,4,14,4" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AboutBuild}" Foreground="White" FontSize="40" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding AboutUptimeLabel}" FontWeight="Bold" Foreground="#B0B0B0" FontSize="36" Margin="0,4,14,4" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AboutUptime}" Foreground="White" FontSize="40" />

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding AboutLicenseLabel}" FontWeight="Bold" Foreground="#B0B0B0" FontSize="36" Margin="0,4,14,4" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AboutLicense}" Foreground="White" FontSize="40" />

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding AboutPermissionsLabel}" FontWeight="Bold" Foreground="#B0B0B0" FontSize="36" Margin="0,4,14,4" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding AboutPermissions}" Foreground="White" FontSize="40" />

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding AboutSupportEmailLabel}" FontWeight="Bold" Foreground="#B0B0B0" FontSize="36" Margin="0,4,14,4" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding AboutSupportEmail}" Foreground="#ACACAC" FontSize="40" />
                                    </Grid>
                                    <TextBlock Text="" Height="28" />
                                </StackPanel>
                            </Border>

                            <!-- FOOTER -->
                            <StackPanel Spacing="2" Margin="0,4,0,0">
                                <TextBlock Text="" Height="28" />
                                <TextBlock Text="{Binding AboutForever}" FontSize="28" Foreground="#6E6E6E" />
                                <TextBlock Text="{Binding AboutAllRightsReserved}" FontSize="28" Foreground="#6E6E6E" />
                                <TextBlock Text="{Binding AboutUnauthorizedArguments}"
                                           FontSize="28" FontStyle="Italic" Foreground="#6E6E6E" />
                                <TextBlock Text="" Height="28" />
                            </StackPanel>

                            <!-- OK Button -->
                                    <Button Content="OK"
                                        Click="OnAboutCloseClicked"
                                        Background="#888888"
                                        BorderBrush="#666666"
                                        BorderThickness="1"
                                        Foreground="#222222"
                                        CornerRadius="8"
                                        Width="180"
                                        Height="70"
                                        FontSize="50"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Center" />

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Panel>
        </Panel>
    </DockPanel>

</Window>
